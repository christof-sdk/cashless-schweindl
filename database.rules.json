{
  "rules": {
    ".read": false,
    ".write": false,

    "jars": {
      "$jarId": {
        ".read": true,
        ".write": true,

        "name": { ".validate": "newData.isString() && newData.val().length <= 60" },
        "goal": { ".validate": "newData.isNumber() && newData.val() > 0 && newData.val() <= 100000" },
        "total": { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "onboarded": { ".validate": "newData.isBoolean()" },
        "payoutAccountHolder": { ".validate": "newData.isString() && newData.val().length <= 100" },
        "payoutAccountIban": { ".validate": "newData.isString() && newData.val().length <= 50" },
        "payoutThreshold": { ".validate": "newData.isNumber() && newData.val() > 0 && newData.val() <= 1000" },
        "colorScheme": { ".validate": "newData.isString() && (newData.val() == '1' || newData.val() == '2')" },
        "ownerUid": { ".validate": "!data.exists() && auth != null && newData.val() === auth.uid" },

        "taps": {
          "$tapKey": {
            ".validate": "newData.hasChildren(['amount', 'timestamp', 'status'])",

            "amount": { ".validate": "newData.isNumber() && newData.val() > 0 && newData.val() <= 20" },
            "timestamp": { ".validate": "newData.isNumber() && newData.val() <= now + 60000" },
            "status": { ".validate": "newData.isString() && (newData.val() == 'pending' || newData.val() == 'confirmed' || newData.val() == 'charging')" },

            "payerUid": { ".validate": "auth != null && newData.isString() && newData.val() === auth.uid" },

            "$other": { ".validate": false }
          }
        },

        "$other": { ".validate": false }
      }
    },

    "payerProfiles": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",

        "customerId": { ".validate": "newData.isString() && newData.val().matches(/^cus_[A-Za-z0-9]+$/)" },
        "paymentMethodId": { ".validate": "newData.isString() && newData.val().matches(/^pm_[A-Za-z0-9]+$/)" },
        "cardBrand": { ".validate": "newData.isString()" },
        "cardLast4": { ".validate": "newData.isString()" },

        "$other": { ".validate": false }
      }
    },

    "settingsAuth": {
      "$jarId": {
        ".read": false,
        ".write": "auth != null && auth.uid === root.child('jars/' + $jarId + '/ownerUid').val()",

        "hash": { ".validate": "newData.isString() && newData.val().matches(/^[a-f0-9]{64}$/)" },
        "salt": { ".validate": "newData.isString() && newData.val().matches(/^[a-f0-9]{32}$/)" },

        "$other": { ".validate": false }
      }
    },

    "archive": {
      "$jarId": {
        "$timestamp": {
          ".read": true,
          ".write": true
        }
      }
    }
  }
}
